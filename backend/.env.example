# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/stellar_trust_escrow

# ── Stellar Network ───────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
# Contract address after deployment
CONTRACT_ADDRESS=
# Soroban RPC endpoint
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT secret for session tokens (optional — see Issue #20)
JWT_SECRET=change_this_in_production

# ── Indexer ───────────────────────────────────────────────────────────────────
# How often to poll for new contract events (milliseconds)
INDEXER_POLL_INTERVAL_MS=5000
# Ledger sequence to start indexing from (set to contract deploy ledger)
INDEXER_START_LEDGER=0
